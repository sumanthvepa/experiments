{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CBRWS V1 Greeting Relation Schema",
  "description": "JSON Schema for the /api/greeting response",
  "_links": {
    "up": {
      "href": "{{ relations_url }}"
    }
  },
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "example": "Hello, world!"
    },
    "_links": {
      "type": "object",
      "properties": {
        "self": {
          "type": "object",
          "properties": {
            "href": { "type": "string", "format": "uri" },
            "type": { "type": "string" },
            "profile": { "type": "string", "format": "uri" }
          },
          "required": ["href", "type", "profile"]
        },
        "up": {
          "type": "object",
          "properties": {
            "href": { "type": "string", "format": "uri" },
            "type": { "type": "string" },
            "profile": { "type": "string", "format": "uri" }
          },
          "required": ["href", "type", "profile"]
        }
      },
      "required": ["self", "up"]
    }
  },
  "required": ["message", "_links"]
}
