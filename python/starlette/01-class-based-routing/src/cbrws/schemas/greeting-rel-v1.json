{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "{{ schema_url }}",
  "title": "{{ title }}",
  "description": "{{ description }}",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "The greeting message returned by the endpoint."
    },
    "_links": {
      "type": "object",
      "description": "HAL link collection for navigating from the greeting response.",
      "properties": {
        "self": {
          "type": "object",
          "description": "Link to the greeting endpoint itself.",
          "properties": {
            "href": { "type": "string", "format": "uri" },
            "type": { "type": "string" },
            "profile": { "type": "string", "format": "uri" }
          },
          "required": ["href", "type", "profile"]
        },
        "up": {
          "type": "object",
          "description": "Link to the parent resource (the /api discovery endpoint).",
          "properties": {
            "href": { "type": "string", "format": "uri" },
            "type": { "type": "string" },
            "profile": { "type": "string", "format": "uri" }
          },
          "required": ["href", "type", "profile"]
        }
      },
      "required": ["self", "up"]
    }
  },
  "required": ["message", "_links"],
  "examples": [
    {
      "message": "Hello, world!",
      "_links": {
        "self": {
          "href": "https://example.com/api/greeting",
          "type": "application/hal+json",
          "profile": "https://example.com/profiles/cbrws/v1/rels/greeting"
        },
        "up": {
          "href": "https://example.com/api",
          "type": "application/hal+json",
          "profile": "https://example.com/profiles/cbrws/v1"
        }
      }
    }
  ]
}
