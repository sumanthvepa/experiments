{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "{{ title }}",
  "description": "JSON Schema for the CBRWS v1 relations index",
  "_links": {
    "up": {
      "href": "{{ profile_url }}"
    }
  },
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "const": "{{ title }}"
    },
    "profile": {
      "type": "string",
      "format": "uri",
      "const": "{{ profile_url }}"
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "href": { "type": "string", "format": "uri" }
        },
        "required": ["name", "href"]
      }
    }
  },
  "required": ["title", "profile", "relations"],
  "examples": [
    {
      "title": "{{ title }}",
      "profile": "{{ profile_url }}",
      "relations": [
        {
          "name": "cbrws:greeting",
          "href": "{{ greeting_relation_url }}"
        }
      ]
    }
  ]
}
